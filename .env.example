# Gemini AI Key (required for AI Chat Assistant)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP URL
APP_URL="MY_APP_URL"

# ── Supabase ─────────────────────────────────────────────────────────
# Project URL (found in Supabase Dashboard → Project Settings → API)
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Anon / Public key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# Service Role key (NEVER expose in frontend — server-side only, bypasses RLS)
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"
